ALLOWED_ORIGINS=http://localhost:5001,http://localhost:5173

# Groq (https://console.groq.com) — fast inference; used by the `groq` Python package
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI-compatible client (same `openai` package): use xAI Grok XOR Groq-hosted models.
# xAI Grok: GROK_BASE_URL=https://api.x.ai/v1 and GROK_MODEL=grok-* 
# Groq via OpenAI SDK: https://api.groq.com/openai/v1 (NOT https://api.groq.com/v1 — that 404s)
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-latest

# Optional: if you previously set only AI_MODEL=grok-* , that still works as an alias for GROK_MODEL

LOCAL_SUMMARY_MODEL=knkarthick/meeting-summary-samsum
