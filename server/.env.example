PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/mcms_db
JWT_SECRET=supersecretkey
CLIENT_URL=http://localhost:5173
AI_SERVICE_URL=http://localhost:8000

# LiveKit WebRTC Configuration (Required for video calls)
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Redis configuration (Required for multi-instance scaling via Socket.IO adapter)
REDIS_URL=redis://127.0.0.1:6379

# Email configuration
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ── Speech-to-Text ───────────────────────────────────────────
# STT_PROVIDER=deepgram   → low-latency Google-Meet-style live captions (recommended)
# STT_PROVIDER=sarvam     → legacy saaras:v3 (slow finals only)
# Defaults to "deepgram" if DEEPGRAM_API_KEY is set, else "sarvam".
STT_PROVIDER=deepgram

# Deepgram (https://deepgram.com — $200 free credit on signup)
DEEPGRAM_API_KEY=
#
# DEEPGRAM_MODEL accepts:
#   flux        → flux-general-en   (Flux v2, English-only, fastest turn-taking)
#   flux-multi  → flux-general-multi (Flux v2, supports en/es/fr/de/hi/ru/pt/ja/it/nl)
#   nova-3      → Nova-3 streaming (Listen v1, supports per-locale tuning incl. en-IN)
#   nova-2 / nova-3-general / etc. also pass through
DEEPGRAM_MODEL=flux
#
# DEEPGRAM_LANGUAGE behavior depends on the model:
#   • flux-general-en   → IGNORED. Model handles all English accents (incl. Indian
#                         English) but has no per-locale variant. en-IN is NOT a
#                         thing on Flux EN.
#   • flux-general-multi → Comma/space-separated language hints. Locale subtags
#                          (en-IN, pt-BR) are normalized to the base code (en, pt).
#                          Use "en,hi" for English/Hindi code-switching.
#                          Leave empty for auto-detect.
#   • nova-3 / nova-2   → A single locale code. Indian English speakers should
#                         set this to "en-IN" — Nova-3 has en-IN-specific tuning.
DEEPGRAM_LANGUAGE=en-US
# Tighten endpointing for snappier finals (ms of silence after speech).
DEEPGRAM_ENDPOINTING_MS=300
DEEPGRAM_UTTERANCE_END_MS=1000

# Sarvam (legacy fallback)
SARVAM_API_KEY=
